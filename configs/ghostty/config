# Ghostty Terminal Configuration
# Docs: https://ghostty.org/docs/config

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

# Theme
theme = TokyoNight

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true
# macOS-only; ignored on Linux
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration (auto-detected, but can be explicit)
shell-integration = zsh

# Copy/paste behavior
copy-on-select = clipboard
clipboard-paste-protection = false

# Scrollback
scrollback-limit = 150000

# Mouse
mouse-hide-while-typing = true

# Custom key bindings
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+enter=new_split:right
keybind = cmd+enter=new_split:down

# SSH integration (pass through ctrl+space for remote tmux)
shell-integration-features = ssh-terminfo,ssh-env

# Jump between command prompts (Warp-like navigation)
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

background-opacity = 0.95
background-image-opacity = 0.1
maximize = true
clipboard-trim-trailing-spaces = true
background-image = ./mikael-gustafsson-wallpaper-mikael-gustafsson.jpg
confirm-close-surface = false
