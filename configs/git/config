[core]
    pager = delta
    excludesFile = ~/.config/git/ignore

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[pull]
    rebase = true

[rebase]
    autoStash = true

[rerere]
    enabled = true

[diff]
    algorithm = histogram

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true
    hyperlinks = true

[merge]
    conflictstyle = zdiff3
